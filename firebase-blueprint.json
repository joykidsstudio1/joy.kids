{
  "entities": {
    "User": {
      "title": "User",
      "description": "A platform user",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["email", "name", "createdAt", "updatedAt"]
    },
    "Channel": {
      "title": "Channel",
      "description": "A YouTube channel connected by the user.",
      "type": "object",
      "properties": {
        "youtubeChannelId": { "type": "string" },
        "title": { "type": "string" },
        "thumbnail": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["youtubeChannelId", "title", "createdAt", "updatedAt"]
    },
    "Script": {
      "title": "Script",
      "description": "An AI-generated text script for a video.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "content", "createdAt", "updatedAt"]
    },
    "Plan": {
      "title": "Plan",
      "description": "An AI-generated content plan.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["weekly", "monthly", "custom"] },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["title", "type", "content", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data."
    },
    "/users/{userId}/channels/{channelId}": {
      "schema": "Channel",
      "description": "Channels saved by the user."
    },
    "/users/{userId}/scripts/{scriptId}": {
      "schema": "Script",
      "description": "Scripts generated by the user."
    },
    "/users/{userId}/plans/{planId}": {
      "schema": "Plan",
      "description": "Plans generated by the user."
    }
  }
}
